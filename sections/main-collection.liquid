<section class="section" {{ section.shopify_attributes }}>
  <div class="container">
    <div class="collection-hero">
      <div class="collection-hero__copy">
        <div class="eyebrow">Colección</div>
        <h1 class="heading-lg" style="margin-top:10px;">{{ collection.title }}</h1>
        {% if collection.description != blank %}
          <p class="text-muted" style="margin-top:16px;max-width:640px;">{{ collection.description }}</p>
        {% endif %}
        <div style="margin-top:24px;">
          <a href="{{ routes.all_products_collection_url }}" class="text-link" style="font-weight:700;">Ver todo el catálogo →</a>
        </div>
      </div>
      <div class="collection-media collection-hero__media" style="aspect-ratio:4 / 3;">
        {% if collection.image != blank %}
          {{ collection.image | image_url: width: 1400 | image_tag: loading: 'lazy', alt: collection.title }}
        {% else %}
          <img src="https://images.unsplash.com/photo-1491637639811-60e2756cc1c7?w=1400&h=1000&fit=crop" alt="{{ collection.title }}" loading="lazy" width="1400" height="1000">
        {% endif %}
      </div>
    </div>

    {% paginate collection.products by 12 %}
      <div class="collection-grid collection-grid--catalog" style="margin-top:48px;">
        {% for product in collection.products %}
          {% render 'product-card', product: product %}
        {% else %}
          <div class="card card--soft" style="padding:40px;grid-column:1 / -1;">
            <div class="heading-sm">No hay productos en esta colección.</div>
            <div class="text-muted" style="margin-top:8px;">Pronto agregaremos nuevas piezas a esta selección.</div>
          </div>
        {% endfor %}
      </div>

      {% if paginate.pages > 1 %}
        <div class="pagination-row" style="margin-top:32px;display:flex;justify-content:center;gap:12px;flex-wrap:wrap;">
          {% if paginate.previous %}
            <a class="button button--secondary" href="{{ paginate.previous.url }}">Anterior</a>
          {% endif %}
          {% if paginate.next %}
            <a class="button button--secondary" href="{{ paginate.next.url }}">Siguiente</a>
          {% endif %}
        </div>
      {% endif %}
    {% endpaginate %}
  </div>
</section>

{% schema %}
{
  "name": "Main collection",
  "settings": []
}
{% endschema %}
