                <a class="text-link" href="/products/lux-leather-wallet" style="font-size:0.75rem;font-weight:700;">Ver →</a>
              </div>
            </div>
          </article>
          <article class="product-card demo-product-card">
            <a href="/products/lux-sunglasses-classic" class="product-card__media">
              <img src="https://images.unsplash.com/photo-1511499767150-a48a237f0083?w=900&h=900&fit=crop" alt="Gafas Classic" loading="lazy" width="900" height="900">
              <div style="position:absolute;left:16px;top:16px;display:flex;gap:8px;flex-wrap:wrap;">
                <span class="badge badge--dark">Nuevo</span>
                <span class="badge badge--gold">Destacado</span>
              </div>
            </a>
            <div class="product-card__content">
              <div class="meta-row" style="align-items:flex-start;">
                <div style="min-width:0;">
                  <a href="/products/lux-sunglasses-classic"><h3 class="product-card__title">Gafas Classic</h3></a>
