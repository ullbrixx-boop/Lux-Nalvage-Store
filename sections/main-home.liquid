              </div>
            </div>
          </article>
          <article class="product-card demo-product-card">
            <a href="/products/lux-backpack-urban" class="product-card__media">
              <img src="https://images.unsplash.com/photo-1553062407-98eeb64c6a62?w=900&h=900&fit=crop" alt="Mochila Urban" loading="lazy" width="900" height="900">
              <div style="position:absolute;left:16px;top:16px;display:flex;gap:8px;flex-wrap:wrap;">
                <span class="badge badge--gold">Destacado</span>
              </div>
            </a>
            <div class="product-card__content">
              <div class="meta-row" style="align-items:flex-start;">
                <div style="min-width:0;">
                  <a href="/products/lux-backpack-urban"><h3 class="product-card__title">Mochila Urban</h3></a>
                  <div class="text-muted" style="margin-top:4px;font-size:0.8rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">Impermeable · Compartimentos inteligentes</div>
                </div>
                <span class="icon-button" aria-hidden="true">{% render 'icon', icon: 'heart' %}</span>
              </div>
              <div class="product-card__price-row" style="margin-top:18px;">
                <div><div style="font-weight:700;">{{ 219900 | money }}</div></div>
                <a class="text-link" href="/products/lux-backpack-urban" style="font-size:0.75rem;font-weight:700;">Ver →</a>
              </div>
            </div>
          </article>
          <article class="product-card demo-product-card">
            <a href="/products/lux-notebook-premium" class="product-card__media">
              <img src="https://images.unsplash.com/photo-1544816155-12df9643f363?w=900&h=900&fit=crop" alt="Libreta Premium" loading="lazy" width="900" height="900">
              <div style="position:absolute;left:16px;top:16px;display:flex;gap:8px;flex-wrap:wrap;">
                <span class="badge badge--gold">Destacado</span>
              </div>
            </a>
            <div class="product-card__content">
              <div class="meta-row" style="align-items:flex-start;">
                <div style="min-width:0;">
                  <a href="/products/lux-notebook-premium"><h3 class="product-card__title">Libreta Premium</h3></a>
                  <div class="text-muted" style="margin-top:4px;font-size:0.8rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">Papel de calidad · Tapa rígida</div>
