{% liquid
  assign featured_collection = section.settings.featured_collection
  if featured_collection == blank
    assign featured_collection = collections['featured']
  endif
  assign category_source = section.settings.category_collection_list
  assign fallback_collection_handles = 'featured,new,all' | split: ','
%}
<section class="hero home-hero" {{ section.shopify_attributes }}>
  <div class="container section home-hero__shell" style="padding-top:80px; padding-bottom:80px;">
    <div class="hero__grid home-hero__grid">
      <div class="hero__copy home-hero__copy">
        <div class="hero__tagline">Lux Nalvage</div>
        <h1 class="heading-xl home-hero__title" style="margin-top:24px;">{{ section.settings.hero_title }}</h1>
        <p class="home-hero__text">{{ section.settings.hero_text }}</p>
        <div class="hero__actions home-hero__actions">
          <a class="button" href="{{ section.settings.primary_link | default: routes.all_products_collection_url }}">{{ section.settings.primary_label }}</a>
          <a class="button button--secondary" href="{{ section.settings.secondary_link | default: routes.collections_url | append: '/featured' }}">{{ section.settings.secondary_label }}</a>
        </div>
        <div class="home-hero__microcopy">Pago contra entrega, confirmación humana y una selección diseñada para inspirar confianza antes de venderte nada.</div>
      </div>
      <div class="hero__media home-hero-media home-hero__media" style="aspect-ratio:4 / 4.2;position:relative;">
        {% if section.settings.hero_image != blank %}
          {{ section.settings.hero_image | image_url: width: 1600 | image_tag: loading: 'lazy', alt: shop.name }}
        {% else %}
          <img src="https://images.unsplash.com/photo-1441986300917-64674bd600d8?w=1200&h=1400&fit=crop" alt="{{ shop.name }}" loading="lazy" width="1200" height="1400">
        {% endif %}
        <div class="home-hero__caption home-hero__caption--top">
          <span class="eyebrow">Curaduría visual</span>
          <strong>Porque la confianza la das tu, y la magia la hacemos nosotros Lux Nalvage en Chile.</strong>
        </div>
        <div class="home-hero__caption home-hero__caption--bottom">
          <span>Selección sobria</span>
          <span>Contra entrega</span>
          <span>Atención real</span>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section home-section home-section--trust">
  <div class="container">
    <div class="section-intro home-section-intro">
      <div>
        <div class="eyebrow">Confianza inmediata</div>
        <h2 class="heading-md" style="margin-top:10px;">Cuatro pilares para comprar con tranquilidad.</h2>
      </div>
    </div>
    <div class="feature-strip grid-4 trust-pillars" style="margin-top:32px;">
      <div class="card card--soft trust-pillar">
        <span class="value-grid__icon">{% render 'icon', icon: 'shield' %}</span>
        <div>
          <h3 class="heading-sm">Compra segura</h3>
          <div class="text-muted" style="margin-top:8px;">Te acompañamos antes del envío y resolvemos tus dudas con claridad.</div>
        </div>
      </div>
      <div class="card card--soft trust-pillar">
        <span class="value-grid__icon">{% render 'icon', icon: 'truck' %}</span>
        <div>
          <h3 class="heading-sm">Pago contra entrega</h3>
          <div class="text-muted" style="margin-top:8px;">Recibes primero, pagas después. Sin fricción, sin promesas vacías.</div>
        </div>
      </div>
      <div class="card card--soft trust-pillar">
        <span class="value-grid__icon">{% render 'icon', icon: 'message' %}</span>
        <div>
          <h3 class="heading-sm">Soporte humano</h3>
          <div class="text-muted" style="margin-top:8px;">Atención rápida por WhatsApp y correo para que nunca compres a ciegas.</div>
        </div>
      </div>
      <div class="card card--soft trust-pillar">
        <span class="value-grid__icon">{% render 'icon', icon: 'check-circle' %}</span>
        <div>
          <h3 class="heading-sm">Selección curada</h3>
          <div class="text-muted" style="margin-top:8px;">Menos ruido, mejor criterio y piezas con presencia premium real.</div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section home-section home-section--categories">
  <div class="container">
    <div class="section-intro home-section-intro">
      <div>
        <div class="eyebrow">Categorías</div>
        <h2 class="heading-md" style="margin-top:10px;">Explora por intención, no por ruido.</h2>
      </div>
      <a class="text-link" href="{{ routes.all_products_collection_url }}" style="font-weight:700;">Ver todo →</a>
    </div>
    <div class="collection-grid home-category-grid" style="margin-top:32px;">
      {% if category_source != blank %}
        {% for collection in category_source limit: 3 %}
          <a class="category-card home-category-card" href="{{ collection.url }}">
            <div class="category-card__media" style="aspect-ratio:4 / 4;position:relative;">
              {% if collection.image != blank %}
                {{ collection.image | image_url: width: 900 | image_tag: loading: 'lazy', alt: collection.title }}
              {% else %}
                <img src="https://images.unsplash.com/photo-1483985988355-763728e1935b?w=900&h=900&fit=crop" alt="{{ collection.title }}" loading="lazy" width="900" height="900">
              {% endif %}
            </div>
            <div class="category-card__content home-category-card__content" style="position:relative;margin-top:-112px;color:white;z-index:1;">
              <div class="heading-sm" style="color:white;">{{ collection.title }}</div>
              {% if collection.description != blank %}
                <div style="margin-top:8px;color:rgba(255,255,255,0.82);">{{ collection.description | strip_html | truncate: 84 }}</div>
              {% endif %}
            </div>
          </a>
        {% endfor %}
      {% else %}
        {% assign rendered_fallback_collection = false %}
        {% for collection_handle in fallback_collection_handles limit: 3 %}
          {% assign collection = collections[collection_handle] %}
          {% if collection != blank %}
            {% assign rendered_fallback_collection = true %}
            <a class="category-card home-category-card" href="{{ collection.url }}">
              <div class="category-card__media" style="aspect-ratio:4 / 4;position:relative;">
                {% if collection.image != blank %}
                  {{ collection.image | image_url: width: 900 | image_tag: loading: 'lazy', alt: collection.title }}
                {% else %}
                  <img src="https://images.unsplash.com/photo-1483985988355-763728e1935b?w=900&h=900&fit=crop" alt="{{ collection.title }}" loading="lazy" width="900" height="900">
                {% endif %}
              </div>
              <div class="category-card__content home-category-card__content" style="position:relative;margin-top:-112px;color:white;z-index:1;">
                <div class="heading-sm" style="color:white;">{{ collection.title }}</div>
                {% if collection.description != blank %}
                  <div style="margin-top:8px;color:rgba(255,255,255,0.82);">{{ collection.description | strip_html | truncate: 84 }}</div>
                {% endif %}
              </div>
            </a>
          {% endif %}
        {% endfor %}
        {% unless rendered_fallback_collection %}
          <a class="category-card home-category-card" href="{{ routes.collections_url }}/essential">
              <div class="category-card__media" style="aspect-ratio:4 / 4;position:relative;">
              <img src="https://images.unsplash.com/photo-1524592094714-0f0654e20314?w=900&h=900&fit=crop" alt="Essentials" loading="lazy" width="900" height="900">
              </div>
              <div class="category-card__content home-category-card__content" style="position:relative;margin-top:-112px;color:white;z-index:1;">
              <div class="heading-sm" style="color:white;">Essentials</div>
              <div style="margin-top:8px;color:rgba(255,255,255,0.82);">Objetos funcionales y sobrios para el día a día.</div>
              </div>
          </a>
          <a class="category-card home-category-card" href="{{ routes.collections_url }}/new">
            <div class="category-card__media" style="aspect-ratio:4 / 4;position:relative;">
              <img src="https://images.unsplash.com/photo-1511499767150-a48a237f0083?w=900&h=900&fit=crop" alt="Nuevos ingresos" loading="lazy" width="900" height="900">
            </div>
            <div class="category-card__content home-category-card__content" style="position:relative;margin-top:-112px;color:white;z-index:1;">
              <div class="heading-sm" style="color:white;">Nuevos ingresos</div>
              <div style="margin-top:8px;color:rgba(255,255,255,0.82);">Selección fresca con piezas de alto impacto visual.</div>
            </div>
          </a>
          <a class="category-card home-category-card" href="{{ routes.collections_url }}/travel-tech">
            <div class="category-card__media" style="aspect-ratio:4 / 4;position:relative;">
              <img src="https://images.unsplash.com/photo-1553062407-98eeb64c6a62?w=900&h=900&fit=crop" alt="Travel & Tech" loading="lazy" width="900" height="900">
            </div>
            <div class="category-card__content home-category-card__content" style="position:relative;margin-top:-112px;color:white;z-index:1;">
              <div class="heading-sm" style="color:white;">Travel & Tech</div>
              <div style="margin-top:8px;color:rgba(255,255,255,0.82);">Accesorios compactos, inteligentes y listos para acompañarte.</div>
            </div>
          </a>
        {% endunless %}
      {% endif %}
    </div>
  </div>
</section>

<section class="section home-section home-section--products">
  <div class="container">
    <div class="section-intro home-section-intro">
      <div>
        <div class="eyebrow">Destacados</div>
        <h2 class="heading-md" style="margin-top:10px;">Productos destacados con presencia premium.</h2>
      </div>
      <a class="text-link" href="{{ featured_collection.url | default: routes.all_products_collection_url }}" style="font-weight:700;">Ver destacados →</a>
    </div>
    <div class="product-grid home-product-grid" style="margin-top:32px;">
      {% if featured_collection != blank and featured_collection.products_count > 0 %}
        {% for product in featured_collection.products limit: 6 %}
          {% render 'product-card', product: product %}
        {% endfor %}
      {% else %}
        {% assign rendered_catalog_fallback = false %}
        {% for product in collections['all'].products limit: 6 %}
          {% assign rendered_catalog_fallback = true %}
          {% render 'product-card', product: product %}
        {% endfor %}
        {% unless rendered_catalog_fallback %}
          <article class="product-card demo-product-card">
            <a href="/products/lux-minimal-watch" class="product-card__media">
              <img src="https://images.unsplash.com/photo-1524592094714-0f0654e20314?w=900&h=900&fit=crop" alt="Reloj Minimal" loading="lazy" width="900" height="900">
              <div style="position:absolute;left:16px;top:16px;display:flex;gap:8px;flex-wrap:wrap;">
                <span class="badge badge--dark">Nuevo</span>
                <span class="badge badge--gold">Destacado</span>
              </div>
            </a>
            <div class="product-card__content">
              <div class="meta-row" style="align-items:flex-start;">
                <div style="min-width:0;">
                  <a href="/products/lux-minimal-watch"><h3 class="product-card__title">Reloj Minimal</h3></a>
                  <div class="text-muted" style="margin-top:4px;font-size:0.8rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">Acero cepillado · Cristal resistente</div>
                </div>
                <span class="icon-button" aria-hidden="true">{% render 'icon', icon: 'heart' %}</span>
              </div>
              <div class="product-card__price-row" style="margin-top:18px;">
                <div>
                  <div style="font-weight:700;">{{ 189900 | money }}</div>
                  <div class="product-card__price-compare">{{ 229900 | money }}</div>
                </div>
                <a class="text-link" href="/products/lux-minimal-watch" style="font-size:0.75rem;font-weight:700;">Ver →</a>
              </div>
            </div>
          </article>
          <article class="product-card demo-product-card">
            <a href="/products/lux-premium-earbuds" class="product-card__media">
              <img src="https://images.unsplash.com/photo-1590658268037-6bf12165a8df?w=900&h=900&fit=crop" alt="Auriculares Premium" loading="lazy" width="900" height="900">
              <div style="position:absolute;left:16px;top:16px;display:flex;gap:8px;flex-wrap:wrap;">
                <span class="badge badge--gold">Destacado</span>
              </div>
            </a>
            <div class="product-card__content">
              <div class="meta-row" style="align-items:flex-start;">
                <div style="min-width:0;">
                  <a href="/products/lux-premium-earbuds"><h3 class="product-card__title">Auriculares Premium</h3></a>
                  <div class="text-muted" style="margin-top:4px;font-size:0.8rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">Sonido limpio · Estuche compacto</div>
                </div>
                <span class="icon-button" aria-hidden="true">{% render 'icon', icon: 'heart' %}</span>
              </div>
              <div class="product-card__price-row" style="margin-top:18px;">
                <div><div style="font-weight:700;">{{ 159900 | money }}</div></div>
                <a class="text-link" href="/products/lux-premium-earbuds" style="font-size:0.75rem;font-weight:700;">Ver →</a>
              </div>
            </div>
          </article>
          <article class="product-card demo-product-card">
            <a href="/products/lux-leather-wallet" class="product-card__media">
              <img src="https://images.unsplash.com/photo-1627123424574-724758594e93?w=900&h=900&fit=crop" alt="Billetera Slim" loading="lazy" width="900" height="900">
              <div style="position:absolute;left:16px;top:16px;display:flex;gap:8px;flex-wrap:wrap;">
                <span class="badge badge--dark">Nuevo</span>
              </div>
            </a>
            <div class="product-card__content">
              <div class="meta-row" style="align-items:flex-start;">
                <div style="min-width:0;">
                  <a href="/products/lux-leather-wallet"><h3 class="product-card__title">Billetera Slim</h3></a>
                  <div class="text-muted" style="margin-top:4px;font-size:0.8rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">Perfil delgado · Tacto suave</div>
                </div>
                <span class="icon-button" aria-hidden="true">{% render 'icon', icon: 'heart' %}</span>
              </div>
              <div class="product-card__price-row" style="margin-top:18px;">
