{% liquid
  assign featured_tag = 'featured'
  assign new_tag = 'new'
  assign product_image = product.featured_image | default: product.images.first
%}
<article class="product-card">
  <a href="{{ product.url }}" class="product-card__media">
    {% if product_image != blank %}
      {{ product_image | image_url: width: 900 | image_tag: loading: 'lazy', alt: product_image.alt | default: product.title }}
    {% else %}
      {{ 'product-1' | placeholder_svg_tag }}
    {% endif %}
    <div style="position:absolute;left:16px;top:16px;display:flex;gap:8px;">
      {% if product.tags contains new_tag %}
        <span class="badge badge--dark">Nuevo</span>
      {% endif %}
      {% if product.tags contains featured_tag %}
        <span class="badge badge--gold">Destacado</span>
      {% endif %}
    </div>
  </a>
  <div class="product-card__content">
    <div class="meta-row" style="align-items:flex-start;">
      <div style="min-width:0;">
        <a href="{{ product.url }}"><h3 class="product-card__title">{{ product.title }}</h3></a>
        {% if product.metafields.custom.subtitle != blank %}
          <div class="text-muted" style="margin-top:4px;font-size:0.8rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{{ product.metafields.custom.subtitle }}</div>
        {% endif %}
      </div>
      <button type="button" class="icon-button" aria-label="Agregar a favoritos">
        {% render 'icon', icon: 'heart' %}
      </button>
    </div>
    <div class="product-card__price-row" style="margin-top:18px;">
      <div>
        <div style="font-weight:700;">{{ product.price | money }}</div>
        {% if product.compare_at_price > product.price %}
          <div class="product-card__price-compare">{{ product.compare_at_price | money }}</div>
        {% endif %}
      </div>
      <a class="text-link" href="{{ product.url }}" style="font-size:0.75rem;font-weight:700;">Ver →</a>
    </div>
  </div>
</article>
