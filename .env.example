# Shopify Storefront API Configuration
# Reemplaza con tus credenciales de Shopify

VITE_SHOPIFY_STORE_DOMAIN=tu-tienda.myshopify.com
VITE_SHOPIFY_STOREFRONT_TOKEN=token_de_storefront_aqui

# Para obtener el token:
# 1. Ve a tu admin de Shopify
# 2. Settings > Apps and sales channels > Develop apps
# 3. Create an app > Configuration
# 4. Enable "Storefront API integration"
# 5. Install app y copia el Storefront access token
